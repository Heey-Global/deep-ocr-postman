        {
          "name": "Process Invoice",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Invoice file (PDF, PNG, JPG, JPEG, WebP). Max 10 MB."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/v1/ocr?document_type=invoice",
              "host": ["{{base_url}}"],
              "path": ["v1", "ocr"],
              "query": [
                {
                  "key": "document_type",
                  "value": "invoice",
                  "description": "Optimizes extraction for invoices: vendor, customer, line items, totals, payment details."
                }
              ]
            },
            "description": "Extract structured data from an invoice.\n\n**Extracted fields include:**\n- Vendor & customer information\n- Invoice number & dates (invoice date, due date)\n- Line items with quantities, unit prices, totals\n- Subtotal, tax rate, tax amount, total\n- Currency\n- Payment details (IBAN, bank)"
          },
          "response": []
